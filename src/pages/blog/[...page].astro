---
import type { GetStaticPaths } from "astro";
import Pagination from "@/components/control/Pagination.astro";
import PostPage from "@/components/PostPage.astro";
import { PAGE_SIZE } from "@/constants/constants";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getRawSortedPosts } from "@/utils/content-utils";

export const getStaticPaths = (async ({ paginate }) => {
	const allBlogPosts = await getRawSortedPosts("all-public");
	return paginate(allBlogPosts, { pageSize: PAGE_SIZE });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const len = page.data.length;
---

<MainGridLayout title="Blog" description="Blog posts">
	<PostPage page={page}></PostPage>
	<Pagination
		class="mx-auto onload-animation"
		page={page}
		base="/blog"
		style={`animation-delay: calc(var(--content-delay) + ${len * 50}ms)`}
	></Pagination>
</MainGridLayout>
